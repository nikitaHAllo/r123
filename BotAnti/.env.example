# Userbot: получить на https://my.telegram.org
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# После первого входа (без SESSION_STRING) сохраните выведенную строку сюда:
# SESSION_STRING=...

# Бот (Grammy): токен от @BotFather
# BOT_TOKEN=123456:ABC...

# Username бота без @ — если задан, userbot шлёт отчёты о нарушениях в личку с ботом
# BOT_USERNAME=MyBotName

# ID админов (user ID через запятую)
ADMINS=

# Разрешённые чаты (ID через запятую; пусто = все)
ALLOWED_CHATS=

# Куда слать уведомления о нарушениях: me = Избранное, или ID через запятую (2110078216,8220093276)
LOG_CHAT_ID=me

# Фильтры (true/false)
FILTER_PROFANITY=true
FILTER_ADVERTISING=true

# Слова (через запятую)
PROFANITY_WORDS="дурак,блин,идиот,тупой"
AD_KEYWORDS="http,www,t.me"

# Docker: задаётся в docker-compose (DB_PATH=/data/database.db). Для нейросети с хоста:
# OLLAMA_URL=http://host.docker.internal:11434/v1/chat/completions
# (Linux: добавьте в docker-compose extra_hosts: ["host.docker.internal:host-gateway"])
