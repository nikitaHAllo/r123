		"@typescript-eslint/eslint-plugin": "^8.18.0",
		"@typescript-eslint/parser": "^8.18.0",
		"eslint": "^8.57.0",
		"eslint-plugin-import": "^2.32.0",
		"tsx": "^4.20.5",
		"typescript": "^5.9.2",
		"vitest": "^2.1.9",
		"husky": "^9.1.7",
		"lint-staged": "^15.4.3"
	},
	"dependencies": {
		"axios": "^1.13.2",
		"cheerio": "^1.1.2",
		"dotenv": "^17.2.2",
