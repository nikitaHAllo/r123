{
	"name": "botanti",
	"version": "1.0.0",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"dev": "tsx src/index.ts",
		"dev:bot": "tsx src/bot.ts",
		"import:words": "tsx src/import_words.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"start:bot": "node dist/bot.js",
		"lint": "eslint src --ext .ts",
		"lint:fix": "eslint src --ext .ts --fix",
